{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "extends": ["ultracite"],
  "files": {
    "ignore": ["dist", "node_modules", "templates", "**/*.md", "test/fixtures"]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "linter": {
    "rules": {
      "style": {
        "useImportType": "off",
        "useCollapsedElseIf": "off"
      },
      "suspicious": {
        "noConsole": "off",
        "noEmptyBlockStatements": "off",
        "useAwait": "off"
      },
      "complexity": {
        "noVoid": "off",
        "noExcessiveCognitiveComplexity": "off"
      },
      "performance": {
        "useTopLevelRegex": "off",
        "noDelete": "off"
      },
      "nursery": {
        "noExportedImports": "off",
        "noNestedTernary": "off"
      }
    }
  }
}
