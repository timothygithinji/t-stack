{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/react"],
  "files": {
    "includes": [
      "!**/dist",
      "!**/node_modules",
      "!**/.turbo",
      "!**/.output",
      "!**/.vinxi",
      "!**/templates",
      "!packages/templates",
      "!**/*.md",
      "!**/test/fixtures",
      "!**/routeTree.gen.ts",
      "!**/.wrangler"
    ]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    },
    "globals": ["Bun"]
  },
  "assist": {
    "actions": {
      "source": {
        "useSortedInterfaceMembers": "off",
        "organizeImports": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["apps/cli/**"],
      "linter": {
        "rules": {
          "performance": {
            "noNamespaceImport": "off",
            "useTopLevelRegex": "off"
          },
          "complexity": {
            "noVoid": "off",
            "noExcessiveCognitiveComplexity": "off"
          },
          "suspicious": {
            "useAwait": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/cli/scripts/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noEmptyBlockStatements": "off"
          }
        }
      }
    },
    {
      "includes": ["**/test/**", "**/*.test.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "useAwait": "off",
            "noEmptyBlockStatements": "off",
            "noEmptySource": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/web/src/components/ui/**"],
      "linter": {
        "rules": {
          "performance": {
            "noNamespaceImport": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/*/src/index.ts"],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          }
        }
      }
    }
  ]
}
