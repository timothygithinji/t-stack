{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "extends": ["ultracite/biome/core"],
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!**/.turbo",
      "!**/.output",
      "!**/.vinxi",
      "!**/templates/**",
      "!packages/templates/**",
      "!**/*.md",
      "!**/test/fixtures/**"
    ]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "useSortedInterfaceMembers": "off",
        "organizeImports": "off"
      }
    }
  },
  "linter": {
    "rules": {
      "style": {
        "useImportType": "off",
        "useCollapsedElseIf": "off",
        "noNestedTernary": "off",
        "noExportedImports": "off",
        "useConsistentArrowReturn": "off",
        "useConsistentTypeDefinitions": "off",
        "noNegationElse": "off"
      },
      "suspicious": {
        "noConsole": "off",
        "noEmptyBlockStatements": "off",
        "useAwait": "off",
        "noEmptySource": "off",
        "noBiomeFirstException": "off",
        "useBiomeIgnoreFolder": "off"
      },
      "complexity": {
        "noVoid": "off",
        "noExcessiveCognitiveComplexity": "off",
        "noUselessUndefined": "off",
        "useSimplifiedLogicExpression": "off"
      },
      "performance": {
        "useTopLevelRegex": "off",
        "noDelete": "off",
        "noNamespaceImport": "off"
      }
    }
  }
}
