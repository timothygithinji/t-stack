{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".output/**",
        ".vinxi/**",
        "files/**",
        "src/lib/generated/**",
        "templates/**"
      ],
      "inputs": [
        "src/**",
        "scripts/**",
        "presets/**",
        "files/**",
        "package.json",
        "tsconfig.json",
        "vite.config.ts",
        "wrangler.jsonc",
        "components.json"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**",
        "test/**",
        "presets/**",
        "files/**",
        "vitest.config.ts"
      ]
    },
    "lint": {
      "outputs": []
    },
    "@t-stack/templates#build": {
      "outputs": [],
      "inputs": ["files/**"]
    },
    "@t-stack/schema#build": {
      "outputs": [],
      "inputs": ["src/**"]
    },
    "@t-stack/presets#build": {
      "outputs": [],
      "inputs": ["src/**"]
    },
    "@t-stack/templating#build": {
      "outputs": [],
      "inputs": ["src/**"]
    }
  }
}
