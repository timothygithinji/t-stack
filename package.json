{
  "name": "@timothygithinji/t-stack",
  "version": "0.1.1",
  "description": "Personal project bootstrapper that goes beyond scaffolding — creates cloud resources, pushes secrets, deploys",
  "type": "module",
  "license": "MIT",
  "author": "Timothy Githinji",
  "homepage": "https://github.com/timothygithinji/t-stack#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timothygithinji/t-stack.git"
  },
  "bugs": {
    "url": "https://github.com/timothygithinji/t-stack/issues"
  },
  "keywords": [
    "cli",
    "scaffolder",
    "cloudflare-workers",
    "doppler",
    "neon",
    "pulumi",
    "tanstack-start",
    "bun"
  ],
  "bin": {
    "t-stack": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "presets",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node --format esm --packages=external",
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "bunx ultracite check",
    "lint:fix": "bunx ultracite fix",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "bun run scripts/smoke.ts",
    "sync-template": "bun run scripts/sync-template.ts",
    "release:dry": "release-it --dry-run",
    "prepare": "husky 2>/dev/null || true"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@octokit/rest": "^21.0.2",
    "@pulumi/cloudflare": "^5.42.0",
    "@pulumi/pulumi": "^3.140.0",
    "citty": "^0.1.6",
    "comment-json": "^4.2.5",
    "consola": "^3.2.3",
    "execa": "^9.5.1",
    "handlebars": "^4.7.8",
    "libsodium-wrappers": "^0.7.15",
    "ofetch": "^1.4.1",
    "pathe": "^1.1.2",
    "proper-lockfile": "^4.1.2",
    "smol-toml": "^1.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@release-it/conventional-changelog": "9.0.3",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^22.9.0",
    "@types/proper-lockfile": "^4.1.4",
    "husky": "^9.1.7",
    "msw": "^2.6.6",
    "release-it": "17.11.0",
    "typescript": "^5.7.2",
    "ultracite": "7.7.0",
    "vitest": "^2.1.5"
  }
}
