{
  "name": "@timothygithinji/t-stack",
  "version": "0.2.0",
  "description": "Personal project bootstrapper that goes beyond scaffolding — creates cloud resources, pushes secrets, deploys",
  "license": "MIT",
  "author": "Timothy Githinji",
  "homepage": "https://github.com/timothygithinji/t-stack#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timothygithinji/t-stack.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/timothygithinji/t-stack/issues"
  },
  "keywords": [
    "cli",
    "scaffolder",
    "cloudflare-workers",
    "doppler",
    "neon",
    "pulumi",
    "tanstack-start",
    "bun"
  ],
  "type": "module",
  "bin": {
    "t-stack": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "presets",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "copy-templates": "bun run scripts/copy-templates.ts",
    "prebuild": "bun run copy-templates",
    "predev": "bun run copy-templates",
    "pretest": "bun run copy-templates",
    "prepack": "bun run copy-templates && bun run scripts/prepare-publish.ts",
    "postpack": "bun run scripts/restore-publish.ts",
    "build": "bun run scripts/build.ts",
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "bun run scripts/smoke.ts",
    "sync-template": "bun run scripts/sync-template.ts",
    "release": "release-it",
    "release:dry": "release-it --dry-run"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "1.4.0",
    "@octokit/rest": "22.0.1",
    "@pulumi/cloudflare": "6.16.0",
    "@pulumi/pulumi": "3.242.0",
    "@t-stack/presets": "workspace:*",
    "@t-stack/schema": "workspace:*",
    "@t-stack/templating": "workspace:*",
    "citty": "0.2.2",
    "comment-json": "5.0.0",
    "consola": "3.4.2",
    "execa": "9.6.1",
    "handlebars": "4.7.9",
    "libsodium-wrappers": "0.8.4",
    "ofetch": "1.5.1",
    "pathe": "2.0.3",
    "proper-lockfile": "4.1.2",
    "smol-toml": "1.6.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "11.0.0",
    "@types/libsodium-wrappers": "0.8.2",
    "@types/proper-lockfile": "4.1.4",
    "msw": "2.14.6",
    "release-it": "20.0.1",
    "vitest": "4.1.7"
  }
}
